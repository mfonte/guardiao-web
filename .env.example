# =====================================================================
# Guardião Web — Template de variáveis de ambiente
# =====================================================================
# Copie para .env.local pra overrides locais (.env.local é gitignored).
# Os arquivos .env.{development,uat,production} são versionados sem
# secrets reais — preencha os campos vazios via:
#   firebase apps:sdkconfig WEB --project <projectId>
# =====================================================================

VITE_APP_ENV=
VITE_APP_NAME=

VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=

VITE_ENABLE_ANALYTICS=false
VITE_LOG_LEVEL=debug
